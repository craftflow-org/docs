{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CraftFlow",
  "colors": {
    "primary": "#183059",
    "light": "#6989B1",
    "dark": "#0E1B35"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://craftflow.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@craftflow.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign In",
      "href": "https://app.craftflow.co"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "help/overview",
              "help/quickstart"
            ]
          },
          {
            "group": "Call Recording & Analysis",
            "pages": [
              "help/call-recording/overview",
              "help/call-recording/mobile-recording",
              "help/call-recording/reviewing-recordings"
            ]
          },
          {
            "group": "Call Center AI",
            "pages": [
              "help/call-center-ai/overview",
              "help/call-center-ai/scorecards",
              "help/call-center-ai/coaching"
            ]
          },
          {
            "group": "AI Voice Agent",
            "pages": [
              "help/voice-agent/overview"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "help/integrations/overview",
              "help/integrations/servicetitan",
              "help/integrations/hubspot"
            ]
          },
          {
            "group": "Account & Settings",
            "pages": [
              "help/account/team-management",
              "help/account/settings"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/introduction",
              "api/authentication"
            ]
          }
        ]
      },
      {
        "tab": "Security",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "security/overview"
            ]
          },
          {
            "group": "Data & Privacy",
            "pages": [
              "security/data-privacy"
            ]
          },
          {
            "group": "Compliance",
            "pages": [
              "security/compliance"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Book a Demo",
          "href": "https://craftflow.com",
          "icon": "calendar"
        }
      ]
    }
  },
  "footer": {
    "links": [
      {
        "title": "Product",
        "links": [
          { "label": "App", "href": "https://app.craftflow.co" },
          { "label": "Website", "href": "https://craftflow.com" }
        ]
      },
      {
        "title": "Legal",
        "links": [
          { "label": "Privacy Policy", "href": "https://craftflow.com/privacy" },
          { "label": "Terms of Service", "href": "https://craftflow.com/terms" }
        ]
      }
    ]
  }
}
